# Railway completa DATABASE_URL automáticamente al agregar el plugin de PostgreSQL.
# Para probar en tu computadora, poné acá la conexión a tu Postgres local.
DATABASE_URL=postgresql://usuario:password@localhost:5432/genet

# Usuario y contraseña del administrador que se crean la primera vez que arranca el servidor.
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Clave secreta para firmar las sesiones de administrador. Cambiala por algo largo y random.
JWT_SECRET=cambiar-esto-por-una-clave-larga-y-secreta

PORT=3000
